generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* ----------------------------------------
          User Deatils Part Start 
-----------------------------------------*/

model Account {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  type                String?
  provider            String?
  provider_account_id String?
  refresh_token       String?
  access_token        String?
  expires_at          DateTime?
  token_type          String?
  scope               String?
  id_token            String?
  session_state       String?

  @@unique([provider, provider_account_id])
  @@map("accounts")
}

enum UserType {
  ADMIN
  HOMEOWNER
  MAID
}

enum ServiceType {
  GENERAL_CLEANING
  DEEP_CLEANING
}

model User {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?
  status     Int?      @default(1) @db.SmallInt

  first_name String?   @db.VarChar(255)
  last_name  String?   @db.VarChar(255)
  avatar     String?
  bio        String?   @db.Text
  about_me   String?
  email      String?   @unique
  address    String?
  password   String?   @db.VarChar(255)
  type       UserType? @default(MAID)

  experience_years Float?  @default(0.0)
  name             String? @db.VarChar(255)
  location         String? @db.VarChar(255)
  language         String? @db.VarChar(100)

  fcm_token   String?
  device_type String? 

  // billing info  
  billing_id        String?
  // stripe connect account 
  stripe_connect_id String?
  //user balance
  balance           Decimal?  @default(0.0) @db.Decimal(10, 2)
  // email verification
  email_verified_at DateTime?
  //distination for maid and homeowner

  //----------------------------------------
  domain        String?   @unique
  username      String?   @unique
  phone_number  String?
  country       String?
  state         String?
  city          String?
  zip_code      String?
  gender        String?
  date_of_birth DateTime? @db.Date
  approved_at   DateTime?
  availability  Boolean   @default(true)
  is_two_factor_enabled Int?    @default(0)
  two_factor_secret     String?

  service_type ServiceType[]

  // Profil & account
  accounts Account[]

  // Review & Rating
  homeownerReviews Review[] @relation("HomeownerReviews")
  maidReviews      Review[] @relation("MaidReviews")

  // Booking
  maidBookings Booking[] @relation("MaidBookings")
  userBookings Booking[] @relation("UserBookings")

  // Conversation & Messaging 
  participants Participant[] @relation("participantUser")
  sentMessages Message[]     @relation("messageSender")

  // Notifications 
  receivedNotifications Notification[] @relation("notificationReceiver")
  sentNotifications     Notification[] @relation("notificationSender")

  // maid verification
  maidVerification MaidVerification[] @relation("maidVerification")

  // others 
  user_payment_methods UserPaymentMethod[]
  ucodes               Ucode[]
  role_users           RoleUser[]
  payment_transactions PaymentTransaction[]

  //destination with user
  destinations   Destination[]
  //live location with user
  live_locations LiveLocation[]

  // Danger notifications
  danger_notifications Danger[] @relation("DangerNotificationToUser")

  // recods created by user

  @@map("users")
}


enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}


model MaidVerification {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  
  user_id String
  user    User   @relation("maidVerification",fields: [user_id], references: [id], onDelete: Cascade)

  id_card_front String?
  id_card_back  String?
  status        VerificationStatus @default(PENDING)
   
  verified_at DateTime?
  @@map("maid_verifications")
}


model Ucode {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  status     Int?     @default(1) @db.SmallInt

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  token       String?
  email       String?
  expired_at  DateTime?
  verified_at DateTime?

  @@map("ucodes")
}

/* ----------------------------------------
          User Deatils Part End 
-----------------------------------------*/
/* ----------------------------------------
          Booking Part Start 
-----------------------------------------*/

enum serviceType {
  GENERAL_CLEANING
  DEEP_CLEANING
}

enum PackageType {
  ECO_SPARK
  SPARK
  GREENFLOW
  GLIDE
}

enum Slot {
  A
  B
  C
  D
}

enum BookingStatus {
  PENDING
  CONFIRMED
  STARTED 
  SUBMITTED
  COMPLETED
  REJECTED
  CANCELLED
}

model GeneralCleaningPackage {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  title       String?
  serviceType serviceType @default(GENERAL_CLEANING)
  packageType PackageType
  image       String?
  description String?
  duration    String?
  price       Decimal?    @db.Decimal(10, 2)

  booking Booking[] @relation("GeneralCleaningPackageBookings")

  @@map("general_cleaning_packages")
}

model DeepCleaningPackage {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  title       String?
  serviceType serviceType @default(DEEP_CLEANING)
  packageType PackageType
  image       String?
  description String?
  duration    String?
  price       Decimal?    @db.Decimal(10, 2)

  booking Booking[] @relation("DeepCleaningPackageBookings")

  @@map("deep_cleaning_packages")
}

model Booking {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  maid_id String
  maid    User   @relation("MaidBookings", fields: [maid_id], references: [id], onDelete: Cascade)

  user_id String
  user    User   @relation("UserBookings", fields: [user_id], references: [id], onDelete: Cascade)

  deep_cleaning_package_id String?
  deep_cleaning_package    DeepCleaningPackage? @relation("DeepCleaningPackageBookings", fields: [deep_cleaning_package_id], references: [id], onDelete: Cascade)

  general_cleaning_package_id String?
  general_cleaning_package    GeneralCleaningPackage? @relation("GeneralCleaningPackageBookings", fields: [general_cleaning_package_id], references: [id], onDelete: Cascade)

  // link to danger notification
  danger_notification Danger? @relation("DangerNotificationToBooking")


  booking_date DateTime @db.Date
  slot         Slot

  maid_location      String
  homeowner_location String

  before_photos String[]
  after_photos  String[]

  total_price Decimal?      @db.Decimal(10, 2)
  status      BookingStatus @default(PENDING)

  booking_destinations Destination[]
  live_locations       LiveLocation[]

  booking_reviews Review[] @relation("BookingReviews")

  @@unique([maid_id, booking_date, slot])
  @@map("bookings")
}

model Destination {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  booking_id String
  booking    Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  pickup_lat Float?
  pickup_lng Float?

  dropoff_lat Float?
  dropoff_lng Float?

  distance_km   Float?
  distance_text String?
  duration_min  Float?

  @@index([booking_id])
  @@map("destinations")
}

// danger notification

enum DangerStatus {
  PENDING
  COMPLETED
  REJECTED
}

model Danger {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  latitude  Float
  longitude Float
  maid_current_location      String?
 
  status DangerStatus @default(PENDING)

  booking_id           String? @unique
  booking               Booking? @relation("DangerNotificationToBooking", fields: [booking_id], references: [id], onDelete: Cascade)

  user_id String?
  user    User?   @relation("DangerNotificationToUser", fields: [user_id], references: [id], onDelete: Cascade)

  @@map("danger")
}


model LiveLocation {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  booking_id String
  booking    Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  latitude  Float
  longitude Float

  @@index([booking_id])
  @@map("live_locations")
}

model Review {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  deleted_at DateTime?

  booking_id String
  booking    Booking @relation("BookingReviews", fields: [booking_id], references: [id], onDelete: Cascade)

  homeowner_id String
  homeowner    User   @relation("HomeownerReviews", fields: [homeowner_id], references: [id], onDelete: Cascade)

  maid_id String
  maid    User   @relation("MaidReviews", fields: [maid_id], references: [id], onDelete: Cascade)

  rating  Int?    @db.SmallInt
  comment String? @db.Text

  @@unique([booking_id, homeowner_id, maid_id])
  @@index([booking_id])
  @@map("reviews")
}

/* ----------------------------------------
          Booking Part  End
-----------------------------------------*/
/* ----------------------------------------
          Conversation Part start
-----------------------------------------*/


model Conversation {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     Message[]
  participants Participant[]
}

model Participant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("participantUser", fields: [userId], references: [id], onDelete: Cascade)

  role     String?  @default("participant")
  joinedAt DateTime @default(now())

  lastReadAt DateTime?

  @@unique([conversationId, userId])
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  PENDING
}

model Message {
  id        String   @id @default(cuid())
  text      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status MessageStatus @default(PENDING)

  senderId String
  sender   User   @relation("messageSender", fields: [senderId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  attachments String[] @db.Text
}

/* ----------------------------------------
          Conversation Part  End
-----------------------------------------*/
/* ----------------------------------------
          Notification Part start
-----------------------------------------*/


model NotificationEvent {
  id            String         @id @default(uuid())
  created_at    DateTime       @default(now())
  updated_at    DateTime       @default(now()) @updatedAt
  deleted_at    DateTime?

  status        Int?           @default(1) @db.SmallInt
  type          String?
  text          String?
  notifications Notification[]
}

model Notification {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  deleted_at DateTime?
  read_at    DateTime?
  status     Int?      @default(1) @db.SmallInt

  sender_id String?
  sender    User?   @relation("notificationSender", fields: [sender_id], references: [id])

  receiver_id String?
  receiver    User?   @relation("notificationReceiver", fields: [receiver_id], references: [id])

  notification_event_id String?
  notification_event    NotificationEvent? @relation(fields: [notification_event_id], references: [id])

  entity_id String?
}

/* ----------------------------------------
          Notification Part End
-----------------------------------------*/

model Role {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status Int?    @default(1) @db.SmallInt
  title  String?
  name   String?

  permission_roles PermissionRole[]
  role_users       RoleUser[]
  permissions      Permission[]     @relation("PermissionToRole")

  @@map("roles")
}

model Permission {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status     Int?    @default(1) @db.SmallInt
  title      String?
  action     String?
  subject    String?
  conditions String?
  fields     String?

  permission_roles PermissionRole[]
  roles            Role[]           @relation("PermissionToRole")

  @@map("permissions")
}

model PermissionRole {
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  permission_id String
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  role_id String
  role    Role   @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([permission_id, role_id])
  @@map("permission_roles")
}

model RoleUser {
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  role_id String
  role    Role   @relation(fields: [role_id], references: [id], onDelete: Cascade)

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([role_id, user_id])
  @@map("role_users")
}

model UserPaymentMethod {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  payment_method_id String?
  checkout_id       String?

  @@map("user_payment_methods")
}

model PaymentTransaction {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  store_id String?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  order_id         String?
  type             String?  @default("order")
  withdraw_via     String?  @default("wallet")
  provider         String?
  reference_number String?
  status           String?  @default("pending")
  raw_status       String?
  amount           Decimal?
  currency         String?
  paid_amount      Decimal?
  paid_currency    String?

  @@map("payment_transactions")
}

model Faq {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status     Int?    @default(1) @db.SmallInt
  sort_order Int?    @default(0)
  question   String?
  answer     String?

  @@map("faqs")
}

model Contact {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  first_name   String?
  last_name    String?
  email        String?
  phone_number String?
  message      String?

  @@map("contacts")
}

// General application settings, such as site title, contact info, etc.
model Setting {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  key   String? @unique
  value String?

  @@map("settings")
}

model Slider {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  title       String?
  description String?
  image       String?
  link        String?

  @@map("sliders")
}


model Testimonial {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  name    String?
  quote   String?
  avatar  String?

  @@map("testimonials")
}



